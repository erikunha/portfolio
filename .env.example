# Anthropic — claude-haiku-4-5-20251001 for /api/ask
# Get from: console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis — rate limiting + monthly token budget
# Get from: console.upstash.com > your DB > REST API tab
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Resend — contact form email delivery
# Get from: resend.com > API Keys
RESEND_API_KEY=re_...

# DEPLOY_SALT — OPTIONAL server-only salt mixed into SHA-256 IP hashing
# (lib/ip-hash.ts). If unset in production, lib/ip-hash.ts auto-generates a
# random 32-byte salt on first request and persists it in Upstash KV at the
# key `meta:deploy-salt`. Subsequent requests + future deploys read the same
# value, so the salt is stable until the Upstash record is wiped.
#
# Resolution order on each cold start:
#   1. process.env.DEPLOY_SALT          — explicit operator-set value
#   2. Upstash `meta:deploy-salt`       — auto-generated and SETNX-persisted
#   3. literal 'portfolio'              — non-production fallback only
#
# Threat model: without a secret salt, an attacker who suspects a target IP
# can SHA-256 it against the known fallback ('portfolio') and confirm
# presence in any leaked KV record (err:* or ask:log:*) — the salt collapses
# to negligible privacy. The auto-generated Upstash value preserves the
# threat model with zero operator action. Rotating invalidates prior per-IP
# rate-limit accounting and Q+A audit hash correlations; rotate on
# suspected leak by DEL'ing the Upstash key (a new value generates on next
# request) rather than on schedule.
#
# Set explicitly only when you want a specific value (e.g., to share a salt
# across two environments deliberately, or to recover from accidental
# Upstash wipe). Generate with:
#   openssl rand -base64 32
DEPLOY_SALT=

# Google PageSpeed Insights — live Lighthouse scores for LIVE_PERF.JSON section
# Get from: console.cloud.google.com > APIs & Services > Credentials > Create API Key
# Enable "PageSpeed Insights API" in the Library first
# Application Restrictions must be "None" — server-side fetch sends no Referer header
PSI_API_KEY=AIza...

# /api/ask kill switch — emergency stop without redeploy of code.
# Any of these values (case-insensitive, trimmed) disables the route and
# returns 503 with the email-fallback message:
#   false | 0 | off | no | disabled
# Anything else (including unset) keeps /api/ask live. Cold-start log line
# `[ask] kill-switch on cold start: <value>` shows the deployed value.
ASK_ENABLED=true
