{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "upstash": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/mcp-server@latest",
        "--email",
        "${UPSTASH_EMAIL}",
        "--api-key",
        "${UPSTASH_READONLY_API_KEY}"
      ]
    }
  }
}
