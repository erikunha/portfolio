{
  "name": "erik-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "pnpm tokens:build",
    "build": "next build",
    "start": "next start",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lhci": "lhci autorun",
    "lhci:mobile": "lhci autorun --config=lighthouserc.mobile.json",
    "tokens:build": "tsx design-system/sd.config.ts",
    "tokens:check": "tsx design-system/sd.config.ts && git diff --exit-code design-system/dist/",
    "validate-content": "tsx scripts/validate-content.ts",
    "ask:eval": "TSX_TSCONFIG_PATH=scripts/tsconfig.eval.json tsx scripts/ask-eval.ts",
    "bundle-check": "node scripts/check-bundle-size.mjs",
    "bundle:analyze": "ANALYZE=true next build",
    "check:client-naming": "node scripts/check-client-naming.mjs",
    "check:dep-pinning": "node scripts/check-dep-pinning.mjs",
    "check:component-docs": "node scripts/check-component-docs-coverage.mjs",
    "check:pkg-age": "node scripts/check-pkg-age.mjs",
    "check:harness-size": "node scripts/check-harness-size.mjs",
    "lint:token-boundary": "node scripts/lint-token-boundary.mjs",
    "lint:no-magic-values": "node scripts/lint-no-magic-values.mjs",
    "lint:contrast": "node scripts/contrast-check.mjs",
    "pr:comments": "node scripts/inspect-pr-comments.mjs",
    "pr:gate": "tsx scripts/check-pr-comments.ts",
    "pr-size": "tsx scripts/pr-size.ts",
    "pr-metrics": "tsx scripts/pr-metrics.ts",
    "ready-for-pr": "tsx scripts/ready-for-pr.ts",
    "copilot-gate": "tsx scripts/check-copilot-approval.ts",
    "ready-to-merge": "tsx scripts/ready-to-merge.ts",
    "test:mutation": "stryker run",
    "verify": "pnpm check && pnpm typecheck && pnpm validate-content && pnpm check:client-naming && pnpm check:dep-pinning && pnpm check:harness-size && pnpm test",
    "ci": "pnpm verify && pnpm build && pnpm bundle-check",
    "ci:local": "pnpm verify",
    "commit": "cz",
    "prepare": "husky || true",
    "postinstall": "node scripts/strip-next-polyfills.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@biomejs/biome"
    ]
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@next/mdx": "16.2.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.190",
    "estree-util-to-js": "2.0.0",
    "estree-util-visit": "2.0.0",
    "mcp-handler": "^1.1.0",
    "next": "~16.2.6",
    "pino": "^10.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-pretty-code": "0.14.3",
    "resend": "^6.12.3",
    "shiki": "4.1.0",
    "zod": "4.4.3"
  },
  "browserslist": [
    "chrome >= 93",
    "edge >= 93",
    "firefox >= 92",
    "safari >= 15.4",
    "not dead"
  ],
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/cz-commitlint": "^21.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/estree": "1.0.9",
    "@types/mdx": "2.0.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "commitizen": "^4.3.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "style-dictionary": "5.4.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
