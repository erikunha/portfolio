{
  "name": "erik-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lhci": "lhci autorun",
    "lhci:mobile": "lhci autorun --config=lighthouserc.mobile.json",
    "validate-content": "tsx scripts/validate-content.ts",
    "generate:og": "tsx scripts/generate-og-image.ts",
    "ask:eval": "TSX_TSCONFIG_PATH=scripts/tsconfig.eval.json tsx scripts/ask-eval.ts",
    "bundle-check": "node scripts/check-bundle-size.mjs",
    "bundle:analyze": "ANALYZE=true next build",
    "check:client-naming": "node scripts/check-client-naming.mjs",
    "check:dep-pinning": "node scripts/check-dep-pinning.mjs",
    "check:component-docs": "node scripts/check-component-docs-coverage.mjs",
    "check:pkg-age": "node scripts/check-pkg-age.mjs",
    "check:harness-size": "node scripts/check-harness-size.mjs",
    "check:section-order": "node scripts/check-section-order.mjs",
    "check:doc-drift": "node scripts/check-doc-drift.mjs",
    "lint:contrast": "node scripts/contrast-check.mjs",
    "pr:comments": "node scripts/inspect-pr-comments.mjs",
    "pr:gate": "tsx scripts/check-pr-comments.ts",
    "pr-size": "tsx scripts/pr-size.ts",
    "validate-pr-body": "tsx scripts/validate-pr-body.ts",
    "pr-metrics": "tsx scripts/pr-metrics.ts",
    "ready-for-pr": "tsx scripts/ready-for-pr.ts",
    "copilot-gate": "tsx scripts/check-copilot-approval.ts",
    "ready-to-merge": "tsx scripts/ready-to-merge.ts",
    "review:stamp": "tsx scripts/review-stamp.ts",
    "test:mutation": "stryker run",
    "verify": "pnpm check && pnpm typecheck && pnpm validate-content && pnpm check:client-naming && pnpm check:dep-pinning && pnpm check:harness-size && pnpm check:section-order && pnpm check:doc-drift && pnpm test",
    "ci": "pnpm verify && pnpm build && pnpm bundle-check",
    "ci:local": "pnpm verify",
    "gates:runtime": "tsx scripts/gates-runtime.ts",
    "prepare": "husky || true",
    "postinstall": "node scripts/strip-next-polyfills.mjs",
    "changelog:sync": "tsx scripts/sync-changelog.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@biomejs/biome"
    ],
    "overrides": {
      "lodash": ">=4.18.0",
      "tmp": "^0.2.6",
      "postcss": ">=8.5.10",
      "qs": ">=6.15.2",
      "uuid": ">=11.1.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "mcp-handler>@modelcontextprotocol/sdk": "1.29.0"
      }
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@next/mdx": "16.2.7",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.196",
    "clsx": "^2.1.1",
    "estree-util-to-js": "2.0.0",
    "estree-util-visit": "2.0.0",
    "mcp-handler": "^1.1.0",
    "next": "~16.2.7",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-pretty-code": "0.14.3",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.4",
    "shiki": "4.2.0",
    "zod": "4.4.3"
  },
  "browserslist": [
    "chrome >= 93",
    "edge >= 93",
    "firefox >= 92",
    "safari >= 15.4",
    "not dead"
  ],
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.7",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/estree": "1.0.9",
    "@types/mdx": "2.0.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  }
}
